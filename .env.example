# DashScope (Qwen) — https://dashscope.console.aliyun.com/
# Read from DASHSCOPE_API_KEY specifically (not a generic "qwen api key").
DASHSCOPE_API_KEY=

# DashScope endpoint. This account is international (home.qwencloud.com),
# so the default (used if this is left blank — see backend/dashscope_config.py)
# is the INTERNATIONAL endpoint:
#   https://dashscope-intl.aliyuncs.com/api/v1
# If you're on a MAINLAND China account instead, set this explicitly to:
#   https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1

# Model names
QWEN_REASONING_MODEL=qwen-max
QWEN_EXTRACTION_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v3

# Alibaba Cloud OSS
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=memorybench-storage
OSS_REGION=cn-hangzhou

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATA_DIR=./backend/data

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
